{
  "manifest_version": 3,
  "name": "YouTube Loop",
  "version": "1.1.2",
  "description": "Zdefiniuj początek i koniec pętli na filmie YouTube i odtwarzaj wybrany fragment w kółko.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
